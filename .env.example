# ── 資料庫 ──
# 本地開發(SQLite):file:./dev.db
# 雲端後台(Supabase Postgres):貼 Session pooler 連線字串(port 5432)
DATABASE_URL="file:./dev.db"

# ── Session ──
SESSION_SECRET="change-me-to-a-random-32-plus-char-string"

# ── 後台密碼 ──
# 本機可暫用明文；production 不接受此欄位
ADMIN_PASSWORD=""
# 正式環境用 bcrypt hash(npx tsx scripts/hash-password.ts "你的密碼")
ADMIN_PASSWORD_HASH=""

# ── Supabase Storage(設了就切換雲端直傳模式)──
# Project Settings → API:Project URL 與 service_role key
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="media"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
